# GitHub Secrets 설정용 템플릿
# 실제 값은 GitHub 저장소 → Settings → Secrets and variables → Actions 에 등록하세요.

# X_AUTH_TOKEN      = 브라우저 x.com 쿠키 auth_token
# X_CT0             = 브라우저 x.com 쿠키 ct0
# ARTIST_ACCOUNTS   = 작가 핸들 (@ 없이, 여러 명이면 쉼표 구분)
# TELEGRAM_BOT_TOKEN = @BotFather 가 준 봇 토큰
# TELEGRAM_CHAT_ID   = Telegram 채팅/채널 ID

# 예시
# ARTIST_ACCOUNTS=artist_name,another_artist
